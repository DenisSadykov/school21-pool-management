# Flask Configuration
FLASK_ENV=development
FLASK_DEBUG=true
SECRET_KEY=your-secret-key-change-in-production
PORT=5000
AUTO_START_WORKERS=false
AUTO_INIT_DB=true
# Production schema changes are run explicitly with `python migrate.py`.
RUN_SCHEMA_MIGRATIONS=false

# Database
DATABASE_URL=sqlite:///pool.db
# Vercel production must use Supavisor Transaction Mode (port 6543).
# DATABASE_URL=postgresql://postgres.project:password@region.pooler.supabase.com:6543/postgres
SERVERLESS_DB_NULL_POOL=true
DATABASE_CONNECT_TIMEOUT=10

# Односторонняя автовыгрузка в оформленные Google Sheets
# URL таблицы и Apps Script задаются отдельно для каждого бассейна в интерфейсе.
# Секрет должен совпадать с SECRET в apps_script/Code.gs.
SYNC_SECRET=change-me

# Daily Excel backups
BACKUP_DIR=backups
BACKUP_INTERVAL=3600

# Стартовый админ
ADMIN_NICK=admin
ADMIN_PASSWORD=admin123

# CORS
FRONTEND_URL=http://localhost:3000,http://localhost:3001

# Telegram bot
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
TELEGRAM_TEST_MODE=true
TELEGRAM_WEBHOOK_SECRET=
INTERNAL_API_SECRET=
TELEGRAM_API_TIMEOUT=8
TELEGRAM_POLL_INTERVAL=2
TELEGRAM_LONG_POLL_TIMEOUT=20
TELEGRAM_QUIET_HOURS_START=23
TELEGRAM_QUIET_HOURS_END=7
SCHOOL_RULES_URL=https://applicant.21-school.ru/rules
