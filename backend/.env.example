# Flask Configuration
FLASK_ENV=development
FLASK_DEBUG=true
SECRET_KEY=your-secret-key-change-in-production
PORT=5000
AUTO_START_WORKERS=false

# Database
DATABASE_URL=sqlite:///pool.db
# production example:
# DATABASE_URL=postgresql://postgres:password@db.xxx.supabase.co:5432/postgres

# Google Sheets sync (через Apps Script Web App, без Google Cloud)
# см. apps_script/README.md
SYNC_WEBHOOK_URL=
SYNC_SECRET=change-me
SYNC_INTERVAL=15

# Daily Excel backups
BACKUP_DIR=backups
BACKUP_INTERVAL=3600

# Стартовый админ
ADMIN_NICK=admin
ADMIN_PASSWORD=admin123

# CORS
FRONTEND_URL=http://localhost:3000,http://localhost:3001

# Telegram bot
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
TELEGRAM_TEST_MODE=true
TELEGRAM_WEBHOOK_SECRET=
INTERNAL_API_SECRET=
TELEGRAM_POLL_INTERVAL=2
TELEGRAM_LONG_POLL_TIMEOUT=20
TELEGRAM_QUIET_HOURS_START=23
TELEGRAM_QUIET_HOURS_END=7
SCHOOL_RULES_URL=https://applicant.21-school.ru/rules
